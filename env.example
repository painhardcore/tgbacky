#
# Environment variables are optional fallbacks. CLI flags win for a single run.
#

#
# Optional profile name. When unset, tgbacky uses the remembered current profile
# when available, otherwise `default`.
#
tgbacky_PROFILE=default

#
# Optional Telegram API credential set. API credentials are app/client
# credentials and can be reused by all Telegram account profiles.
#
tgbacky_API_PROFILE=default

#
# Optional Telegram API credentials for one run. For normal local use,
# `tgbacky auth` or `tgbacky api add` can prompt for these interactively and
# store them in the OS keychain instead. If keychain is unavailable, tgbacky can
# keep them in a local file after an explicit warning and confirmation.
#
tgbacky_API_ID=123456
tgbacky_API_HASH=0123456789abcdef0123456789abcdef

#
# Optional path overrides. When unset, tgbacky stores profile data under the
# OS application data directory.
#
tgbacky_SESSION_PATH=./data/session.db
tgbacky_DB_PATH=./data/state.db
tgbacky_DOWNLOAD_DIR=./downloads
tgbacky_RUN_ARTIFACT_DIR=./data/run-artifacts

# Logging verbosity for tgbacky itself: error, warn, info, debug, trace.
tgbacky_LOG_LEVEL=error

# Retry a failed media download this many times before marking it failed.
tgbacky_RETRY_COUNT=3

# Base delay in milliseconds before a retry; later retries back off exponentially.
tgbacky_RETRY_BACKOFF_MS=1000

# Abort and retry a media download if no Telegram chunk arrives for this many seconds.
tgbacky_DOWNLOAD_STALL_TIMEOUT_SECS=120

# Use stable deterministic filenames, or keep original names when available.
tgbacky_FILENAME_MODE=stable

# Temporary suffix used while a file is still downloading.
tgbacky_TEMP_EXTENSION=.part

# Default media kinds to include when --only/--skip are not provided.
tgbacky_MEDIA_FILTER=photo,image_doc,video,animation,audio,voice,document

# Delay between general Telegram API requests like chat/history reads.
tgbacky_REQUEST_DELAY_MS=400

# Delay between download steps; increase this if you want gentler media pacing.
tgbacky_DOWNLOAD_DELAY_MS=850

# Optional: 0 means "always honor Telegram flood-wait + 1s".
tgbacky_FLOOD_SLEEP_THRESHOLD_SECS=0

# Random jitter added to request/download delays to avoid bursty request patterns.
tgbacky_JITTER_MS=250

# Remove stale .part files on export start.
tgbacky_CLEANUP_STALE_PARTS_ON_START=false

# Minimum age before a .part file is considered stale.
tgbacky_STALE_PART_MIN_AGE_HOURS=12

# Show dependency transport logs too; usually only needed for debugging.
tgbacky_VERBOSE_DEPENDENCY_LOGS=false
